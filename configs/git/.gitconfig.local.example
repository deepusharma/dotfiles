# Copy this to ~/.gitconfig.local and fill in your details
# This file is machine-specific and should never be committed

[user]
    name = Your Name
    email = your.email@example.com

# Generated by `gh auth login` — do not edit manually
[credential "https://github.com"]
    helper =
    helper = !/path/to/gh auth git-credential
[credential "https://gist.github.com"]
    helper =
    helper = !/path/to/gh auth git-credential